# Vigil v1.0 — Configuration
# Copy to .env and customize

# ── Server ──
VIGIL_PORT=4100
VIGIL_USER=admin
VIGIL_PASS=admin
NODE_ENV=production

# ── Database (optional — works without it) ──
# DATABASE_URL=postgresql://vigil:vigil@localhost:5432/vigil

# ── AI Provider (BYOK — bring your own key) ──
# AI_PROVIDER=claude-cli
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Encryption ──
# ENCRYPTION_KEY=  (auto-generated if not set, 32-byte hex)

# ── Docker (for container security scanning) ──
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_GID=0

# ── Scanner Timeouts ──
# SCAN_TIMEOUT=300000
# NMAP_PATH=/usr/bin/nmap
# NUCLEI_PATH=/usr/local/bin/nuclei
# TRIVY_PATH=/usr/local/bin/trivy
