# Vigil v1.1 — Configuration
# Copy to .env and customize
#
# PRODUCTION CHECKLIST:
# 1. Set VIGIL_USER and VIGIL_PASS, or leave VIGIL_PASS blank to auto-generate a bootstrap password
# 2. Set ENCRYPTION_KEY (or leave blank to auto-generate)
# 3. Set DATABASE_URL for persistent storage (optional)
# 4. Configure AI_PROVIDER if using AI features (optional)

# ── Server ──
VIGIL_PORT=4100
VIGIL_USER=admin
VIGIL_PASS=
NODE_ENV=production

# ── Database (optional — works without it, uses JSON file stores) ──
# DATABASE_URL=postgresql://vigil:vigil@localhost:5432/vigil
# Docker Compose: DATABASE_URL=postgresql://vigil:vigil@postgres:5432/vigil

# ── AI Provider ──
# Default: ollama (local, no API key required)
# Options: ollama, claude-api, claude-cli, codex, none
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434   # use http://localhost:11434 for host Ollama
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
#
# Cloud providers (BYOK — bring your own key):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Encryption ──
# Auto-generated on first run if not set (32-byte hex)
# To generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this breaks existing encrypted credentials
# ENCRYPTION_KEY=

# ── Docker (for container security scanning) ──
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_GID=0

# ── Scanner Paths (auto-detected if on PATH) ──
# SCAN_TIMEOUT=300000
# NMAP_PATH=/usr/bin/nmap
# NUCLEI_PATH=/usr/local/bin/nuclei
# TRIVY_PATH=/usr/local/bin/trivy
# NIKTO_PATH=/usr/bin/nikto
# OPENSSL_PATH=/usr/bin/openssl
# DIG_PATH=/usr/bin/dig
# WHOIS_PATH=/usr/bin/whois
